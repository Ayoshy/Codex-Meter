<Window x:Class="CodexUsageTray.UpdateProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Codex Meter — Update"
        Width="440"
        Height="250"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        Background="Transparent"
        Foreground="#F7F8FA"
        FontFamily="Segoe UI Variable Text, Segoe UI"
        ShowInTaskbar="False">
    <Window.Resources>
        <LinearGradientBrush x:Key="AccentGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#58F0AE" Offset="0" />
            <GradientStop Color="#5BC8FF" Offset="0.52" />
            <GradientStop Color="#8A7CFF" Offset="1" />
        </LinearGradientBrush>
        <Style TargetType="ProgressBar">
            <Setter Property="Height" Value="9" />
            <Setter Property="Background" Value="#252E3A" />
            <Setter Property="Foreground" Value="#55E6A5" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid>
                            <Border Background="{TemplateBinding Background}" CornerRadius="5" />
                            <Border x:Name="PART_Track" CornerRadius="5" />
                            <Border x:Name="PART_Indicator"
                                    HorizontalAlignment="Left"
                                    Background="{TemplateBinding Foreground}"
                                    CornerRadius="5" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="RootLayout">
        <Border Margin="16"
                Padding="28"
                Background="#FC0C1016"
                BorderBrush="#34404F"
                BorderThickness="1"
                CornerRadius="22">
            <Grid>
                <Ellipse Width="220"
                         Height="220"
                         Margin="0,-150,-120,0"
                         HorizontalAlignment="Right"
                         VerticalAlignment="Top"
                         IsHitTestVisible="False">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#3055E6A5" Offset="0" />
                            <GradientStop Color="#0055E6A5" Offset="1" />
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>

                <StackPanel VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="28" Height="28" Background="{StaticResource AccentGradient}" CornerRadius="9">
                            <TextBlock HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="#07110D"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       Text="C" />
                        </Border>
                        <TextBlock x:Name="TitleText"
                                   Margin="12,0,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="#F7F8FA"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Text="Updating Codex Meter" />
                    </StackPanel>
                    <TextBlock x:Name="StatusText"
                               Margin="0,20,0,0"
                               Foreground="#A8B3C1"
                               FontSize="11.5"
                               Text="Downloading the update…" />
                    <ProgressBar x:Name="DownloadProgress"
                                 Margin="0,12,0,0"
                                 Minimum="0"
                                 Maximum="100"
                                 Value="0" />
                    <TextBlock x:Name="DetailText"
                               Margin="0,8,0,0"
                               HorizontalAlignment="Right"
                               Foreground="#687587"
                               FontSize="10"
                               Text="0%" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
