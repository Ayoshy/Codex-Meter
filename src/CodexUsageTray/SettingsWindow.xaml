<Window x:Class="CodexUsageTray.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Codex Meter &#x2014; Options"
        Width="500"
        Height="780"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        Background="Transparent"
        Foreground="#F7F8FA"
        FontFamily="Segoe UI Variable Text, Segoe UI"
        ShowInTaskbar="False"
        KeyDown="Window_KeyDown"
        PreviewMouseWheel="Window_PreviewMouseWheel">
    <Window.Resources>
        <SolidColorBrush x:Key="MutedBrush" Color="#8C97A8" />
        <SolidColorBrush x:Key="SubtleBrush" Color="#616D7E" />
        <SolidColorBrush x:Key="CardBrush" Color="#E6161C25" />
        <SolidColorBrush x:Key="BorderBrush" Color="#293240" />
        <SolidColorBrush x:Key="GreenBrush" Color="#55E6A5" />
        <LinearGradientBrush x:Key="AccentGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#58F0AE" Offset="0" />
            <GradientStop Color="#5BC8FF" Offset="0.52" />
            <GradientStop Color="#8A7CFF" Offset="1" />
        </LinearGradientBrush>

        <Style x:Key="ChromeButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#9BA6B5" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ChromeBackground" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ChromeBackground" Property="Background" Value="#222A36" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ChromeBackground" Property="Background" Value="#2B3543" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="16" />
        </Style>

        <Style x:Key="DarkComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#DCE3EC" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="11,8" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBackground" Background="{TemplateBinding Background}" CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBackground" Property="Background" Value="#24303D" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBackground" Property="Background" Value="#263F3A" />
                                <Setter Property="Foreground" Value="#7BF2BD" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="38" />
            <Setter Property="Foreground" Value="#F7F8FA" />
            <Setter Property="Background" Value="#1B232E" />
            <Setter Property="BorderBrush" Value="#344152" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,0,38,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource DarkComboBoxItemStyle}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="ComboBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="10">
                                <Grid>
                                    <ContentPresenter Margin="{TemplateBinding Padding}"
                                                      VerticalAlignment="Center"
                                                      IsHitTestVisible="False"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}" />
                                    <Path Width="8" Height="5" Margin="0,0,14,0" HorizontalAlignment="Right" VerticalAlignment="Center" Fill="#8C97A8" Stretch="Fill" Data="M 0 0 L 4 4 L 8 0 Z" IsHitTestVisible="False" />
                                    <ToggleButton x:Name="DropDownToggle"
                                                  Focusable="False"
                                                  ClickMode="Press"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="Transparent" />
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                </Grid>
                            </Border>
                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   PopupAnimation="Fade">
                                <Border Width="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}" MaxHeight="240" Margin="0,6,0,0" Padding="4" Background="#F5151B24" BorderBrush="#405064" BorderThickness="1" CornerRadius="10">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" CanContentScroll="True">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger SourceName="DropDownToggle" Property="IsMouseOver" Value="True">
                                <Setter TargetName="ComboBorder" Property="Background" Value="#222C38" />
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="#4A5B70" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="#55E6A5" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToggleStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#E8EDF3" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid MinHeight="32">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ContentPresenter VerticalAlignment="Center" Margin="0,0,14,0" Content="{TemplateBinding Content}" TextElement.Foreground="{TemplateBinding Foreground}" />
                            <Border x:Name="Track" Grid.Column="1" Width="42" Height="24" Background="#252E3A" BorderBrush="#3B4858" BorderThickness="1" CornerRadius="12">
                                <Ellipse x:Name="Thumb" Width="16" Height="16" Margin="3" HorizontalAlignment="Left" Fill="#8C97A8" />
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="#25483D" />
                                <Setter TargetName="Track" Property="BorderBrush" Value="#39745F" />
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right" />
                                <Setter TargetName="Thumb" Property="Fill" Value="#55E6A5" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Track" Property="BorderBrush" Value="#5A6B80" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PillButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Background" Value="#1B232E" />
            <Setter Property="Foreground" Value="#DCE3EC" />
            <Setter Property="BorderBrush" Value="#3B4B5F" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBackground" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBackground" Property="Background" Value="#24303D" />
                                <Setter Property="BorderBrush" Value="#55E6A5" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBackground" Property="Background" Value="#2B3847" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="RootLayout">
        <Border Margin="16" Background="#FA0C1016" BorderBrush="#34404F" BorderThickness="1" CornerRadius="22" ClipToBounds="True" SizeChanged="WindowFrame_SizeChanged">
            <Grid>
                <Ellipse Width="330" Height="330" Margin="0,-205,-170,0" HorizontalAlignment="Right" VerticalAlignment="Top" IsHitTestVisible="False">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#3055E6A5" Offset="0" />
                            <GradientStop Color="#0055E6A5" Offset="1" />
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>
                <Ellipse Width="280" Height="280" Margin="-180,0,0,-200" HorizontalAlignment="Left" VerticalAlignment="Bottom" IsHitTestVisible="False">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#247D6CFF" Offset="0" />
                            <GradientStop Color="#007D6CFF" Offset="1" />
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="48" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="20,8,10,0" Background="Transparent" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="22" Height="22" Background="{StaticResource AccentGradient}" CornerRadius="7">
                                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#07110D" FontSize="12" FontWeight="Bold" Text="C" />
                            </Border>
                            <TextBlock Margin="9,0,0,0" VerticalAlignment="Center" Foreground="#B8C2CE" FontSize="12" FontWeight="SemiBold" Text="Codex Meter" />
                            <Border Margin="10,0,0,0" Padding="8,3" VerticalAlignment="Center" Background="#18271F" BorderBrush="#2B5A43" BorderThickness="1" CornerRadius="8">
                                <TextBlock x:Name="OptionsTitleText" Foreground="#75EFB7" FontSize="9.5" FontWeight="Bold" Text="Options" />
                            </Border>
                        </StackPanel>
                        <Button Grid.Column="1" Style="{StaticResource ChromeButtonStyle}" Content="&#x00D7;" Click="CloseButton_Click" />
                    </Grid>

                    <Grid Grid.Row="1" Margin="28,8,28,26">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="16" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock x:Name="OptionsHeaderText" Foreground="{StaticResource GreenBrush}" FontSize="10" FontWeight="Bold" Text="OPTIONS" />
                            <TextBlock x:Name="SettingsSubtitleText" Margin="0,7,0,0" Foreground="#DCE3EC" FontSize="20" FontWeight="SemiBold" Text="Tune Codex Meter to your desk." />
                        </StackPanel>

                        <Border Grid.Row="2" Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="14" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="14" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock x:Name="GeneralHeading" Foreground="{StaticResource SubtleBrush}" FontSize="9.5" FontWeight="Bold" Text="GENERAL" />
                                <Grid Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock x:Name="LanguageLabel" Foreground="{StaticResource MutedBrush}" FontSize="10.5" FontWeight="SemiBold" Text="Language" />
                                        <ComboBox x:Name="LanguageCombo" Margin="0,6,0,0" Style="{StaticResource DarkComboBoxStyle}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock x:Name="IntervalLabel" Foreground="{StaticResource MutedBrush}" FontSize="10.5" FontWeight="SemiBold" Text="Refresh interval" />
                                        <ComboBox x:Name="IntervalCombo" Margin="0,6,0,0" Style="{StaticResource DarkComboBoxStyle}" />
                                    </StackPanel>
                                </Grid>
                                <Grid Grid.Row="4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock x:Name="StartupLabel" Foreground="{StaticResource MutedBrush}" FontSize="10.5" FontWeight="SemiBold" Text="At startup" />
                                        <ComboBox x:Name="StartupCombo" Margin="0,6,0,0" Style="{StaticResource DarkComboBoxStyle}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock x:Name="ScaleLabel" Foreground="{StaticResource MutedBrush}" FontSize="10.5" FontWeight="SemiBold" Text="UI scale" />
                                        <ComboBox x:Name="ScaleCombo" Margin="0,6,0,0" Style="{StaticResource DarkComboBoxStyle}" />
                                    </StackPanel>
                                </Grid>
                                <StackPanel Grid.Row="6">
                                    <TextBlock x:Name="DockCornerLabel" Foreground="{StaticResource MutedBrush}" FontSize="10.5" FontWeight="SemiBold" Text="Compact dock position" />
                                    <ComboBox x:Name="DockCornerCombo" Margin="0,6,0,0" Style="{StaticResource DarkComboBoxStyle}" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Row="4" Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <CheckBox x:Name="AlwaysOnTopToggle" Style="{StaticResource ToggleStyle}" Content="Keep compact widget on top" />
                                <Border Height="1" Margin="0,10" Background="{StaticResource BorderBrush}" />
                                <CheckBox x:Name="StartWithWindowsToggle" Style="{StaticResource ToggleStyle}" Content="Start with Windows" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="6" Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <CheckBox x:Name="ApiEstimateToggle" Style="{StaticResource ToggleStyle}" Content="API-equivalent estimate" />
                                <TextBlock x:Name="EstimateDescription" Grid.Row="1" Margin="0,5,54,0" Foreground="{StaticResource MutedBrush}" FontSize="10.5" Text="Reads local session counters only. No prompts, keys, or telemetry." TextWrapping="Wrap" />
                                <Border Grid.Row="2" Height="1" Margin="0,14,0,12" Background="{StaticResource BorderBrush}" />
                                <Grid Grid.Row="3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="14" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Button x:Name="ClearCacheButton" Style="{StaticResource PillButtonStyle}" Content="Clear local estimate cache" />
                                    <TextBlock x:Name="CacheDescription" Grid.Column="2" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" FontSize="10" Text="Removes Codex Meter's local estimate cache only." TextWrapping="Wrap" />
                                </Grid>
                                <Button x:Name="ResetSettingsButton" Grid.Row="4" Margin="0,12,0,0" HorizontalAlignment="Left" Style="{StaticResource PillButtonStyle}" Content="Reset settings" />
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>

                <Grid x:Name="ConfirmationOverlay"
                      Panel.ZIndex="20"
                      Visibility="Collapsed"
                      Background="#C0000000">
                    <Border Width="356"
                            Padding="22"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Background="#FA171E28"
                            BorderBrush="#405064"
                            BorderThickness="1"
                            CornerRadius="18">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="28" ShadowDepth="8" Opacity="0.65" Color="#000000" />
                        </Border.Effect>
                        <StackPanel>
                            <Border Width="38"
                                    Height="38"
                                    HorizontalAlignment="Left"
                                    Background="#25483D"
                                    BorderBrush="#39745F"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="#75EFB7"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Text="&#x21BA;" />
                            </Border>
                            <TextBlock x:Name="ConfirmationTitleText"
                                       Margin="0,16,0,0"
                                       Foreground="#F7F8FA"
                                       FontSize="17"
                                       FontWeight="SemiBold"
                                       Text="Clear local cache" />
                            <TextBlock x:Name="ConfirmationMessageText"
                                       Margin="0,8,0,0"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontSize="11.5"
                                       Text="Clear Codex Meter's local estimate cache? This does not affect Codex or its sessions."
                                       TextWrapping="Wrap" />
                            <StackPanel Margin="0,20,0,0"
                                        HorizontalAlignment="Right"
                                        Orientation="Horizontal">
                                <Button x:Name="CancelClearButton"
                                        MinWidth="92"
                                        Style="{StaticResource PillButtonStyle}"
                                        Content="Cancel" />
                                <Button x:Name="ConfirmClearButton"
                                        MinWidth="118"
                                        Margin="10,0,0,0"
                                        Style="{StaticResource PillButtonStyle}"
                                        Background="#25483D"
                                        BorderBrush="#39745F"
                                        Foreground="#75EFB7"
                                        Content="Clear local cache" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
