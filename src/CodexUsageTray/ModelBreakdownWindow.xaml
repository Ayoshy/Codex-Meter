<Window x:Class="CodexUsageTray.ModelBreakdownWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Codex Meter — Model details"
        Width="790"
        Height="660"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        Background="Transparent"
        Foreground="#F7F8FA"
        FontFamily="Segoe UI Variable Text, Segoe UI"
        ShowInTaskbar="False"
        KeyDown="Window_KeyDown"
        PreviewMouseWheel="Window_PreviewMouseWheel">
    <Window.Resources>
        <SolidColorBrush x:Key="MutedBrush" Color="#8C97A8" />
        <SolidColorBrush x:Key="SubtleBrush" Color="#616D7E" />
        <SolidColorBrush x:Key="CardBrush" Color="#E6161C25" />
        <SolidColorBrush x:Key="BorderBrush" Color="#293240" />
        <SolidColorBrush x:Key="GreenBrush" Color="#55E6A5" />
        <LinearGradientBrush x:Key="AccentGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#58F0AE" Offset="0" />
            <GradientStop Color="#5BC8FF" Offset="0.52" />
            <GradientStop Color="#8A7CFF" Offset="1" />
        </LinearGradientBrush>

        <Style x:Key="ChromeButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#9BA6B5" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ChromeBackground" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ChromeBackground" Property="Background" Value="#222A36" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SummaryCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="16,13" />
        </Style>

        <Style x:Key="FilterTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="11,0" />
            <Setter Property="Foreground" Value="#F7F8FA" />
            <Setter Property="CaretBrush" Value="#55E6A5" />
            <Setter Property="Background" Value="#161D27" />
            <Setter Property="BorderBrush" Value="#344152" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="TextBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="9">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="TextBorder" Property="BorderBrush" Value="#55E6A5" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TextBorder" Property="BorderBrush" Value="#4A5B70" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HeaderSortButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource SubtleBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="HeaderBackground" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HeaderBackground" Property="Background" Value="#202936" />
                                <Setter Property="Foreground" Value="#DCE3EC" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter Property="Foreground" Value="#55E6A5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="10" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Width="10" Background="Transparent">
                            <Track x:Name="PART_Track" Margin="2" Orientation="{TemplateBinding Orientation}" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}" Opacity="0" Focusable="False" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb MinHeight="28" Cursor="Hand">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border x:Name="ThumbBody" Background="#526174" CornerRadius="3" />
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="ThumbBody" Property="Background" Value="#6E8198" /></Trigger>
                                                    <Trigger Property="IsDragging" Value="True"><Setter TargetName="ThumbBody" Property="Background" Value="#55E6A5" /></Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}" Opacity="0" Focusable="False" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="RootLayout">
        <Border Margin="16" Background="#FA0C1016" BorderBrush="#34404F" BorderThickness="1" CornerRadius="22" ClipToBounds="True" SizeChanged="WindowFrame_SizeChanged">
            <Grid>
                <Ellipse Width="400" Height="400" Margin="0,-260,-210,0" HorizontalAlignment="Right" VerticalAlignment="Top" IsHitTestVisible="False">
                    <Ellipse.Fill><RadialGradientBrush><GradientStop Color="#2E55E6A5" Offset="0" /><GradientStop Color="#0055E6A5" Offset="1" /></RadialGradientBrush></Ellipse.Fill>
                </Ellipse>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="48" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="20,8,10,0" Background="Transparent" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="22" Height="22" Background="{StaticResource AccentGradient}" CornerRadius="7"><TextBlock Text="C" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#07110D" FontSize="12" FontWeight="Bold" /></Border>
                            <TextBlock Text="Codex Meter" Margin="9,0,0,0" VerticalAlignment="Center" Foreground="#B8C2CE" FontSize="12" FontWeight="SemiBold" />
                        </StackPanel>
                        <Button Grid.Column="1" Style="{StaticResource ChromeButtonStyle}" Content="×" Click="CloseButton_Click" />
                    </Grid>

                    <StackPanel Grid.Row="1" Margin="28,15,28,16">
                        <TextBlock x:Name="TitleText" FontSize="25" FontWeight="SemiBold" />
                        <TextBlock x:Name="SubtitleText" Margin="0,6,0,0" Foreground="{StaticResource MutedBrush}" FontSize="11.5" />
                        <TextBlock x:Name="FooterText" Margin="0,9,0,0" Foreground="#8694A6" FontSize="10" TextWrapping="Wrap" LineHeight="15" />
                    </StackPanel>

                    <Grid Grid.Row="2" Margin="28,0,28,14">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="10" /><ColumnDefinition Width="*" /><ColumnDefinition Width="10" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Style="{StaticResource SummaryCardStyle}"><StackPanel><TextBlock x:Name="ObservedTokensLabel" Foreground="{StaticResource SubtleBrush}" FontSize="9" FontWeight="Bold" /><TextBlock x:Name="ObservedTokensValue" Margin="0,6,0,0" FontSize="21" FontWeight="SemiBold" /></StackPanel></Border>
                        <Border Grid.Column="2" Style="{StaticResource SummaryCardStyle}"><StackPanel><TextBlock x:Name="ApiCostLabel" Foreground="{StaticResource SubtleBrush}" FontSize="9" FontWeight="Bold" /><TextBlock x:Name="ApiCostValue" Margin="0,6,0,0" Foreground="{StaticResource GreenBrush}" FontSize="21" FontWeight="SemiBold" /></StackPanel></Border>
                        <Border Grid.Column="4" Style="{StaticResource SummaryCardStyle}"><StackPanel><TextBlock x:Name="ModelsLabel" Foreground="{StaticResource SubtleBrush}" FontSize="9" FontWeight="Bold" /><TextBlock x:Name="ModelsValue" Margin="0,6,0,0" FontSize="21" FontWeight="SemiBold" /><TextBlock x:Name="SessionsValue" Margin="0,2,0,0" Foreground="{StaticResource MutedBrush}" FontSize="10" /></StackPanel></Border>
                    </Grid>

                    <Grid Grid.Row="3" Margin="28,0,28,12">
                        <TextBox x:Name="SearchBox" Style="{StaticResource FilterTextBoxStyle}" TextChanged="SearchBox_TextChanged" />
                        <TextBlock x:Name="SearchHint" Margin="12,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" FontSize="10.5" IsHitTestVisible="False" />
                    </Grid>

                    <Border Grid.Row="4" Margin="28,0,28,0" Background="#B5121720" BorderBrush="#293240" BorderThickness="1" CornerRadius="14" ClipToBounds="True">
                        <Grid>
                            <Grid.RowDefinitions><RowDefinition Height="38" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                            <Grid Grid.Row="0" Background="#181F2A">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="2.1*" /><ColumnDefinition Width="1.1*" /><ColumnDefinition Width="2.3*" /><ColumnDefinition Width="0.9*" /><ColumnDefinition Width="1.2*" /><ColumnDefinition Width="0.9*" /></Grid.ColumnDefinitions>
                                <Button x:Name="ModelSortButton" Grid.Column="0" Style="{StaticResource HeaderSortButtonStyle}" Tag="Model" Click="SortHeader_Click">
                                    <StackPanel Orientation="Horizontal"><TextBlock x:Name="ModelHeader" FontSize="9" FontWeight="Bold" /><TextBlock x:Name="ModelSortIndicator" Margin="5,0,0,0" Foreground="{StaticResource GreenBrush}" FontSize="10" /></StackPanel>
                                </Button>
                                <Button x:Name="EffortSortButton" Grid.Column="1" Style="{StaticResource HeaderSortButtonStyle}" Tag="Effort" Click="SortHeader_Click">
                                    <StackPanel Orientation="Horizontal"><TextBlock x:Name="EffortHeader" FontSize="9" FontWeight="Bold" /><TextBlock x:Name="EffortSortIndicator" Margin="5,0,0,0" Foreground="{StaticResource GreenBrush}" FontSize="10" /></StackPanel>
                                </Button>
                                <Button x:Name="TokensSortButton" Grid.Column="2" Style="{StaticResource HeaderSortButtonStyle}" Tag="Tokens" Click="SortHeader_Click">
                                    <StackPanel Orientation="Horizontal"><TextBlock x:Name="TokensHeader" FontSize="9" FontWeight="Bold" /><TextBlock x:Name="TokensSortIndicator" Margin="5,0,0,0" Foreground="{StaticResource GreenBrush}" FontSize="10" /></StackPanel>
                                </Button>
                                <Button x:Name="SessionsSortButton" Grid.Column="3" Style="{StaticResource HeaderSortButtonStyle}" Tag="Sessions" Click="SortHeader_Click" HorizontalContentAlignment="Right">
                                    <StackPanel Orientation="Horizontal"><TextBlock x:Name="SessionsHeader" FontSize="9" FontWeight="Bold" /><TextBlock x:Name="SessionsSortIndicator" Margin="5,0,0,0" Foreground="{StaticResource GreenBrush}" FontSize="10" /></StackPanel>
                                </Button>
                                <Button x:Name="CostSortButton" Grid.Column="4" Style="{StaticResource HeaderSortButtonStyle}" Tag="Cost" Click="SortHeader_Click" HorizontalContentAlignment="Right">
                                    <StackPanel Orientation="Horizontal"><TextBlock x:Name="CostHeader" FontSize="9" FontWeight="Bold" /><TextBlock x:Name="CostSortIndicator" Margin="5,0,0,0" Foreground="{StaticResource GreenBrush}" FontSize="10" /></StackPanel>
                                </Button>
                                <Button x:Name="ShareSortButton" Grid.Column="5" Style="{StaticResource HeaderSortButtonStyle}" Tag="Share" Click="SortHeader_Click" HorizontalContentAlignment="Right" Padding="10,0,14,0">
                                    <StackPanel Orientation="Horizontal"><TextBlock x:Name="ShareHeader" FontSize="9" FontWeight="Bold" /><TextBlock x:Name="ShareSortIndicator" Margin="5,0,0,0" Foreground="{StaticResource GreenBrush}" FontSize="10" /></StackPanel>
                                </Button>
                            </Grid>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,5">
                                <ItemsControl x:Name="RowsList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="6,2" Padding="8,10" Background="#9A161C25" CornerRadius="9">
                                                <Grid>
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="2.1*" /><ColumnDefinition Width="1.1*" /><ColumnDefinition Width="2.3*" /><ColumnDefinition Width="0.9*" /><ColumnDefinition Width="1.2*" /><ColumnDefinition Width="0.9*" /></Grid.ColumnDefinitions>
                                                    <TextBlock Margin="0,0,6,0" VerticalAlignment="Center" Text="{Binding Model}" TextTrimming="CharacterEllipsis" FontSize="12" FontWeight="SemiBold" />
                                                    <Border Grid.Column="1" Margin="4,0,8,0" Padding="7,4" HorizontalAlignment="Left" VerticalAlignment="Center" Background="#25323F" CornerRadius="9"><TextBlock Text="{Binding Effort}" Foreground="#9FDDF6" FontSize="9" FontWeight="Bold" /></Border>
                                                    <StackPanel Grid.Column="2" Margin="6,0" VerticalAlignment="Center"><TextBlock Text="{Binding Tokens}" FontSize="12" FontWeight="SemiBold" /><TextBlock Text="{Binding TokenDetails}" Margin="0,3,0,0" Foreground="{StaticResource MutedBrush}" FontSize="8.5" TextTrimming="CharacterEllipsis" /></StackPanel>
                                                    <TextBlock Grid.Column="3" Margin="6,0" VerticalAlignment="Center" Text="{Binding Sessions}" FontSize="11" TextAlignment="Right" />
                                                    <TextBlock Grid.Column="4" Margin="6,0" VerticalAlignment="Center" Text="{Binding Cost}" Foreground="{StaticResource GreenBrush}" FontSize="11" FontWeight="SemiBold" TextAlignment="Right" />
                                                    <StackPanel Grid.Column="5" Margin="8,0,0,0" VerticalAlignment="Center"><TextBlock Text="{Binding Share}" FontSize="11" FontWeight="SemiBold" TextAlignment="Right" /><ProgressBar Margin="0,5,0,0" Height="3" Maximum="100" Value="{Binding ShareValue}" Background="#252E3A" Foreground="#55E6A5" BorderThickness="0" /></StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>