<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>CodexMeter</AssemblyName>
    <AssemblyTitle>Codex Meter</AssemblyTitle>
    <Product>Codex Meter</Product>
    <Description>Read-only Codex usage monitor for Windows</Description>
    <RootNamespace>CodexUsageTray</RootNamespace>
    <ApplicationManifest>app.manifest</ApplicationManifest>
  </PropertyGroup>
</Project>
